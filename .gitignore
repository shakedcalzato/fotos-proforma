*.pdf
# .icns en general no van al repo, EXCEPTO AppIcon.icns que es el
# ícono oficial que necesita el workflow build-mac.yml para empaquetar
# el .app con el ícono correcto.
*.icns
!AppIcon.icns
AppIcon.iconset/

# ---- Logs y archivos generados en runtime ----
*.log
.coverage
htmlcov/
